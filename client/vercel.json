{
  "rewrites": [
    {
      "source": "/:orgSlug/events/:slug/register",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Twitterbot|WhatsApp|LinkedInBot|TelegramBot|Slackbot|Discordbot|vkShare|Pinterest|Googlebot).*"
        }
      ],
      "destination": "/api/og-proxy/:orgSlug/:slug"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
